# EduPlan PH - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ===========================================
# API Configuration (REQUIRED)
# ===========================================

# OpenRouter API Key
# Get your free key at: https://openrouter.ai/keys
# This is REQUIRED for the application to function
OPENROUTER_API_KEY=sk-or-v1-YOUR_ACTUAL_API_KEY_HERE

# ===========================================
# Streamlit Configuration (Optional)
# ===========================================

# Server port (default: 8501)
STREAMLIT_SERVER_PORT=8501

# Server address (default: 0.0.0.0 for Docker)
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Disable usage statistics (recommended for production)
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ===========================================
# Application Settings (Optional)
# ===========================================

# Cache database path (relative to app root)
# Leave empty to use default: eduplan_cache.db in app root
CACHE_DB_PATH=eduplan_cache.db

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ===========================================
# Development Settings (Optional)
# ===========================================

# Enable/disable debug mode
# Set to 'true' only in development environments
DEBUG_MODE=false

# Custom models configuration (if needed)
# CUSTOM_MODELS=meta-llama/llama-3-8b-instruct,mistralai/mistral-7b-instruct
