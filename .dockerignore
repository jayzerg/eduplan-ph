# EduPlan PH - .dockerignore file
# Exclude unnecessary files from Docker build context

# Git
.git
.gitignore
.gitattributes

# Documentation
README.md
CHANGELOG.md
LICENSE
docs/
*.md

# Testing
tests/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDE and Editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# Environment files (should not be in container)
.env
.env.local
.env.*.local

# Logs
*.log
streamlit_output.log
logs/

# SQLite database files (will be mounted as volume)
*.db
*.db-journal
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
.tmp/
*.tmp
*.bak
*.backup

# Docker files (don't include them in the build context)
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# Development and debugging
*.pdb
.pytype/
mypy_cache/

# Jupyter notebooks (if any)
.ipynb_checkpoints/

# Coverage reports
coverage.xml
.coverage
