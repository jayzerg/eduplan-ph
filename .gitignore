```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp
*.swp

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
target/
*.o
*.obj
*.out
*.exe
*.dll
*.so
*.a

# Coverage reports
coverage/
htmlcov/
.coverage

# Dependency caches
node_modules/
.mypy_cache/
.pytest_cache/
.npm
.yarn

# System files
.DS_Store
Thumbs.db
```