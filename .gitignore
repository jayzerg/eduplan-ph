```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
env/

# Logs
*.log

# Temporary files
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
*.coverage

# Build artifacts
build/
dist/
target/

# Dependencies cache
.node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/
```